{
	"luci-app-notifip": {
		"description": "Grant UCI and rpcd access for NotifIP",
		"read": {
			"uci": [ "notifip" ],
			"ubus": {
				"luci.notifip": [ "status", "log" ]
			},
			"file": {
				"/etc/notifip/changes.log": [ "read" ],
				"/etc/notifip/state": [ "read" ],
				"/tmp/msmtp.notifip.log": [ "read" ]
			}
		},
		"write": {
			"uci": [ "notifip" ],
			"ubus": {
				"luci.notifip": [ "test_mail", "clear_log", "check_now" ]
			}
		}
	}
}
