config notifip 'general'
	option enabled '0'
	option interval '5'
	option mode 'public'
	list   iface 'wan'
	option boot_mail '1'

config smtp 'smtp'
	option host ''
	option port '587'
	option security 'starttls'
	option user ''
	option password ''
